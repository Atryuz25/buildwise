generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum not supported in SQLite, using String instead

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  email     String?  @unique
  password  String?
  name      String?
  role      String   @default("SITE_ENGINEER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects         ProjectMember[]
  auditsSubmitted  MaterialAudit[]
  estimatesCreated Estimate[]
}

model Project {
  id            String    @id @default(uuid())
  name          String
  location      String
  type          String
  budget        Float
  spent         Float     @default(0)
  concreteGrade String    @default("M25")
  steelGrade    String    @default("Fe500")
  startDate     DateTime
  endDate       DateTime?
  status        String    @default("Active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  members           ProjectMember[]
  materials         Material[]
  audits            MaterialAudit[]
  estimates         Estimate[]
  crews             Crew[]
  delays            Delay[]
  contractors       Contractor[]
  outputs           OutputRecord[]
  paymentMilestones PaymentMilestone[]
}

model ProjectMember {
  id        String @id @default(uuid())
  userId    String
  projectId String
  role      String

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
}

model Material {
  id           String   @id @default(uuid())
  projectId    String
  name         String // e.g., Cement, Steel (8mm), Sand, Aggregate
  unit         String // bags, kg, cft, etc.
  currentStock Float    @default(0)
  minThreshold Float    @default(0)
  burnRate7Day Float    @default(0)
  ratePerUnit  Float    @default(0) // Master rate
  lastUpdated  DateTime @default(now())

  project    Project     @relation(fields: [projectId], references: [id])
  auditItems AuditItem[]

  @@unique([projectId, name])
}

model MaterialAudit {
  id          String   @id @default(uuid())
  projectId   String
  engineerId  String
  date        DateTime @default(now())
  activity    String
  siteNotes   String?
  weather     String // Clear, Cloudy, Light rain, Heavy rain
  overallRisk String // Healthy, Warning, High risk
  createdAt   DateTime @default(now())

  project  Project     @relation(fields: [projectId], references: [id])
  engineer User        @relation(fields: [engineerId], references: [id])
  items    AuditItem[]
}

model AuditItem {
  id              String @id @default(uuid())
  auditId         String
  materialId      String
  estimatedQty    Float
  actualUsed      Float
  variancePercent Float
  riskFlag        String // Healthy, Warning, High risk

  audit    MaterialAudit @relation(fields: [auditId], references: [id])
  material Material      @relation(fields: [materialId], references: [id])
}

model Estimate {
  id         String   @id @default(uuid())
  projectId  String
  engineerId String
  type       String // CONCRETE, STEEL
  structure  String? // Slab, Beam, Column, etc.
  totalCost  Float
  data       String // Stores the exact inputs and outputs as JSON string
  createdAt  DateTime @default(now())

  project  Project @relation(fields: [projectId], references: [id])
  engineer User    @relation(fields: [engineerId], references: [id])
}

model Contractor {
  id          String   @id @default(uuid())
  name        String
  trade       String
  phone       String
  bankDetails String // Encrypted
  createdAt   DateTime @default(now())

  crews    Crew[]
  projects Project[] // implicitly many-to-many or just through crews? Let's just do crews for now.
}

model Crew {
  id           String   @id @default(uuid())
  projectId    String
  contractorId String
  tradeType    String // Masonry, Steel, etc.
  size         Int
  dailyRate    Float    @default(0)
  createdAt    DateTime @default(now())

  project     Project        @relation(fields: [projectId], references: [id])
  contractor  Contractor     @relation(fields: [contractorId], references: [id])
  attendances Attendance[]
  delays      Delay[]
  outputs     OutputRecord[]
}

model OutputRecord {
  id          String   @id @default(uuid())
  crewId      String
  projectId   String
  date        DateTime @default(now())
  actualQty   Float
  targetQty   Float
  variancePct Float
  unit        String
  createdAt   DateTime @default(now())

  crew    Crew    @relation(fields: [crewId], references: [id])
  project Project @relation(fields: [projectId], references: [id])
}

model Attendance {
  id           String   @id @default(uuid())
  crewId       String
  date         DateTime @default(now())
  presentCount Int
  outputUnits  Float    @default(0) // Crew output rate
  notes        String?
  createdAt    DateTime @default(now())

  crew Crew @relation(fields: [crewId], references: [id])
}

model Delay {
  id         String   @id @default(uuid())
  projectId  String
  crewId     String?
  date       DateTime @default(now())
  cause      String
  severity   String // Low, Medium, High
  impactDays Int      @default(0)
  impactCost Float    @default(0)
  notes      String?
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  crew    Crew?   @relation(fields: [crewId], references: [id])
}

model MaterialRate {
  id        String   @id @default(uuid())
  city      String   @unique
  cement    Float // per bag
  steel     Float // per kg
  sand      Float // per cft
  aggregate Float // per cft
  updatedAt DateTime @updatedAt
}

model PaymentMilestone {
  id        String   @id @default(uuid())
  projectId String
  title     String
  amount    Float
  dueDate   DateTime
  status    String   @default("UPCOMING") // UPCOMING, OVERDUE, PAID
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}
