generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enum not supported in SQLite, using String instead

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  email     String?  @unique
  password  String?
  name      String?
  role      String   @default("SITE_ENGINEER")
  isProvisioned Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects          ProjectMember[]
  auditsSubmitted   MaterialAudit[]
  estimatesCreated  Estimate[]
  dailyReports      DailySiteReport[]
  notifications     Notification[]
}

model Project {
  id            String   @id @default(uuid())
  name          String
  location      String
  type          String
  budget        Float
  spent         Float    @default(0)
  concreteGrade String   @default("M25")
  steelGrade    String   @default("Fe500")
  startDate     DateTime
  endDate       DateTime?
  status        String   @default("Active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members       ProjectMember[]
  materials     Material[]
  audits        MaterialAudit[]
  estimates     Estimate[]
  crews         Crew[]
  delays        Delay[]
  contractors   Contractor[]
  outputs       OutputRecord[]
  paymentMilestones PaymentMilestone[]
  dailyReports  DailySiteReport[]
  pileMeasurements PileMeasurement[]
  aiReferencePhotos AiReferencePhoto[]
}

model ProjectMember {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  role      String

  user      User     @relation(fields: [userId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
}

model Material {
  id              String   @id @default(uuid())
  projectId       String
  name            String   // e.g., Cement, Steel (8mm), Sand, Aggregate
  unit            String   // bags, kg, cft, etc.
  currentStock    Float    @default(0)
  minThreshold    Float    @default(0)
  burnRate7Day    Float    @default(0)
  ratePerUnit     Float    @default(0) // Master rate
  lastUpdated     DateTime @default(now())

  project         Project  @relation(fields: [projectId], references: [id])
  auditItems      AuditItem[]
  logs            InventoryLog[]

  @@unique([projectId, name])
}

model InventoryLog {
  id          String   @id @default(uuid())
  materialId  String
  type        String   // DELIVERY, MANUAL_ADJUSTMENT, CONSUMPTION
  quantity    Float
  referenceId String?  // e.g. supplier invoice
  notes       String?
  createdAt   DateTime @default(now())

  material    Material @relation(fields: [materialId], references: [id])
}

model MaterialAudit {
  id             String   @id @default(uuid())
  projectId      String
  engineerId     String
  date           DateTime @default(now())
  activity       String
  siteNotes      String?
  weather        String   // Clear, Cloudy, Light rain, Heavy rain
  overallRisk    String   // Healthy, Warning, High risk
  source         String   @default("MANUAL") // MANUAL, DAILY_REPORT
  createdAt      DateTime @default(now())

  project        Project  @relation(fields: [projectId], references: [id])
  engineer       User     @relation(fields: [engineerId], references: [id])
  items          AuditItem[]
}

model AuditItem {
  id              String   @id @default(uuid())
  auditId         String
  materialId      String
  estimatedQty    Float
  actualUsed      Float
  variancePercent Float
  riskFlag        String   // Healthy, Warning, High risk

  audit           MaterialAudit @relation(fields: [auditId], references: [id])
  material        Material      @relation(fields: [materialId], references: [id])
}

model Estimate {
  id            String   @id @default(uuid())
  projectId     String
  engineerId    String
  type          String   // CONCRETE, STEEL
  structure     String?  // Slab, Beam, Column, etc.
  totalCost     Float
  data          String   // Stores the exact inputs and outputs as JSON string
  createdAt     DateTime @default(now())

  project       Project  @relation(fields: [projectId], references: [id])
  engineer      User     @relation(fields: [engineerId], references: [id])
}

model Contractor {
  id          String   @id @default(uuid())
  name        String
  trade       String
  phone       String
  bankDetails String   // Encrypted
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())

  crews       Crew[]
  projects    Project[] // implicitly many-to-many or just through crews? Let's just do crews for now.
}

model Crew {
  id             String       @id @default(uuid())
  projectId      String
  contractorId   String
  tradeType      String       // Masonry, Steel, etc.
  size           Int
  dailyRate      Float        @default(0)
  targetQty      Float?
  targetUnit     String?
  createdAt      DateTime     @default(now())

  project        Project      @relation(fields: [projectId], references: [id])
  contractor     Contractor   @relation(fields: [contractorId], references: [id])
  attendances    Attendance[]
  delays         Delay[]
  outputs        OutputRecord[]
}

model OutputRecord {
  id           String   @id @default(uuid())
  crewId       String
  projectId    String
  date         DateTime @default(now())
  actualQty    Float
  targetQty    Float
  variancePct  Float
  unit         String
  createdAt    DateTime @default(now())

  crew         Crew     @relation(fields: [crewId], references: [id])
  project      Project  @relation(fields: [projectId], references: [id])
}

model Attendance {
  id           String   @id @default(uuid())
  crewId       String
  date         DateTime @default(now())
  presentCount Int
  outputUnits  Float    @default(0) // Crew output rate
  notes        String?
  createdAt    DateTime @default(now())

  crew         Crew     @relation(fields: [crewId], references: [id])
}

model Delay {
  id          String   @id @default(uuid())
  projectId   String
  crewId      String?
  date        DateTime @default(now())
  cause       String
  severity    String   // Low, Medium, High
  impactDays  Int      @default(0)
  impactCost  Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id])
  crew        Crew?    @relation(fields: [crewId], references: [id])
}

model MaterialRate {
  id        String   @id @default(uuid())
  city      String   @unique
  cement    Float    // per bag
  steel     Float    // per kg
  sand      Float    // per cft
  aggregate Float    // per cft
  updatedAt DateTime @updatedAt
}

model PaymentMilestone {
  id          String   @id @default(uuid())
  projectId   String
  title       String
  amount      Float
  dueDate     DateTime
  status      String   @default("UPCOMING") // UPCOMING, OVERDUE, PAID
  paidDate    DateTime?
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id])
}

model DailySiteReport {
  id          String   @id @default(uuid())
  projectId   String
  engineerId  String
  date        DateTime @default(now())
  status      String   @default("DRAFT") // DRAFT, SUBMITTED
  pmNote      String?
  crewsData   String?  // JSON string storing draft crew usage before submit
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id])
  engineer    User     @relation(fields: [engineerId], references: [id])
  
  activities  ReportActivity[]
  materials   ReportMaterial[]
  issues      ReportIssue[]
  photos      ReportPhoto[]
  delays      ReportDelay[]
}

model ReportActivity {
  id               String   @id @default(uuid())
  reportId         String
  activityName     String
  zone             String?
  status           String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, DELAYED
  expectedProgress String?
  actualProgress   String?

  report           DailySiteReport @relation(fields: [reportId], references: [id])
}

model ReportMaterial {
  id          String   @id @default(uuid())
  reportId    String
  materialId  String
  expected    Float
  actual      Float
  unit        String

  report      DailySiteReport @relation(fields: [reportId], references: [id])
}

model ReportIssue {
  id          String   @id @default(uuid())
  reportId    String
  type        String
  severity    String
  description String

  report      DailySiteReport @relation(fields: [reportId], references: [id])
}

model ReportDelay {
  id          String   @id @default(uuid())
  reportId    String
  cause       String
  hours       Float

  report      DailySiteReport @relation(fields: [reportId], references: [id])
}

model ReportPhoto {
  id          String   @id @default(uuid())
  reportId    String
  s3Key       String?
  caption     String?
  category    String?
  takenAt     DateTime @default(now())
  latitude    Float?
  longitude   Float?

  report      DailySiteReport @relation(fields: [reportId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   
  message   String
  linkTo    String?  // route to navigate on click
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model PileMeasurement {
  id              String   @id @default(uuid())
  projectId       String
  materialType    String
  estimatedVolume Float
  inventoryVolume Float
  divergencePct   Float
  flagged         Boolean  @default(false)
  photoUrl        String?
  gps             String?
  rawAiResponse   String?
  createdBy       String
  createdAt       DateTime @default(now())

  project         Project  @relation(fields: [projectId], references: [id])
}

model AiReferencePhoto {
  id          String   @id @default(uuid())
  projectId   String
  feature     String   // e.g. 'PILE_MEASUREMENT', 'REBAR_CHECK', 'PROGRESS_DETECTION'
  category    String   // e.g. 'Sand', 'Aggregate', 'Clean Rebar'
  metadata    String?  // e.g. '150' (the exact volume/context of the reference)
  photoUrl    String
  uploadedBy  String
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id])
}
